{
  "name": "i18n-excel-manager",
  "version": "2.5.1",
  "description": "DEPRECATED: This package is no longer maintained. Please migrate to @verbatra/cli (https://github.com/mariokreitz/verbatra).",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./cli": "./cli.js"
  },
  "bin": {
    "i18n-excel-manager": "cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:commits": "commitlint --from HEAD~10 --to HEAD",
    "release": "release-it",
    "test:coverage": "c8 --config .c8rc.json node --test && node scripts/check-module-coverage.js"
  },
  "keywords": [
    "angular",
    "i18n",
    "translate",
    "translation",
    "excel",
    "xlsx",
    "converter"
  ],
  "author": "Mario Kreitz <mario.kreitz@web.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/i18n-excel-manager.git"
  },
  "bugs": {
    "url": "https://github.com/mariokreitz/i18n-excel-manager/issues"
  },
  "homepage": "https://github.com/mariokreitz/verbatra",
  "dependencies": {
    "@google/genai": "^2.6.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "exceljs": "^4.3.0",
    "figlet": "^1.11.0",
    "glob": "^13.0.0",
    "inquirer": "^14.0.2",
    "joi": "^18.2.3",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.39.4",
    "@release-it/conventional-changelog": "^11.0.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.4",
    "release-it": "^20.0.1",
    "ts-api-utils": "^2.4.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "undici": "^6.24.1",
    "flatted": "^3.4.2",
    "uuid": "^11.1.1"
  }
}
